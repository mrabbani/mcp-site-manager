{
    "name": "site-mcp/site-mcp",
    "description": "Expose WordPress site management to MCP-aware AI clients.",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "require": {
        "php": ">=8.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.6",
        "yoast/phpunit-polyfills": "^2.0"
    },
    "autoload": {
        "psr-4": { "SiteMcp\\": "includes/" }
    },
    "autoload-dev": {
        "psr-4": { "SiteMcp\\Tests\\": "tests/" }
    },
    "config": {
        "sort-packages": true
    }
}
